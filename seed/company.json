{
  "company": {
    "name": "Pantalasa",
    "tagline": "Building the ocean of connected commerce for the modern enterprise.",
    "summary": "Pantalasa is a global fintech infrastructure company that provides end-to-end payment processing, data analytics, and merchant services. Founded in 2018, we power transactions for over 50,000 businesses across 40 countries, processing billions in annual volume through our unified commerce platform."
